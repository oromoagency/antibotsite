# Copy to .env and fill in your values
# On Render: Settings → Environment Variables

# ── Required ───────────────────────────────────────────────────────────────────

# Session signing key — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-here

# Admin dashboard bearer token — generate with:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_TOKEN=your-admin-token-here

# ── Optional ───────────────────────────────────────────────────────────────────

# HTTP port (Render injects this automatically)
PORT=3000

# Set to 'production' to enable Secure + HttpOnly cookies
NODE_ENV=development

# Zero Bot Mode (default: true)
# false → watermark/poison only, never block
ANTIBOT_ZERO_BOT_MODE=true

# Telegram alerts (optional — real-time bot block notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
