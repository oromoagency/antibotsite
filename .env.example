# Variables d'environnement requises — copier vers .env et remplir les valeurs
# Sur Render : Settings → Environment Variables

# Clé de chiffrement des sessions (AES) — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-here

# Token admin pour le dashboard /admin — générer avec : node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_TOKEN=your-admin-token-here

# Bot Telegram pour les alertes en temps réel
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Port d'écoute (Render l'injecte automatiquement)
PORT=3000
